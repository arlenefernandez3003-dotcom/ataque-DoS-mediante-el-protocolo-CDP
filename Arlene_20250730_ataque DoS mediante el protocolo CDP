# ==============================================================
# CONSTANTES CDP
# ==============================================================

CDP_MULTICAST_MAC = "01:00:0c:cc:cc:cc"
CDP_SNAP_OUI      = b"\x00\x00\x0c"   # Cisco OUI
CDP_SNAP_PID      = b"\x20\x00"        # CDP PID

# TLV Types CDP relevantes
CDP_TLV_DEVICE_ID   = b"\x00\x01"
CDP_TLV_ADDRESS     = b"\x00\x02"
CDP_TLV_PORT_ID     = b"\x00\x03"
CDP_TLV_CAPS        = b"\x00\x04"
CDP_TLV_VERSION     = b"\x00\x05"
CDP_TLV_PLATFORM    = b"\x00\x06"


# ==============================================================
# FUNCIONES AUXILIARES
# ==============================================================

def random_mac() -> str:
    """Genera una MAC aleatoria con el bit unicast local."""
    mac = [
        random.randint(0x00, 0xfe) & 0xFE,  # unicast
        random.randint(0x00, 0xff),
        random.randint(0x00, 0xff),
        random.randint(0x00, 0xff),
        random.randint(0x00, 0xff),
        random.randint(0x00, 0xff)
    ]
    return ":".join(f"{b:02x}" for b in mac)


def build_cdp_tlv(tlv_type: bytes, value: bytes) -> bytes:
    """
    Construye un TLV CDP:
      - Type  : 2 bytes
      - Length: 2 bytes (incluye los 4 bytes del header)
      - Value : variable
    """
    length = len(value) + 4
    return tlv_type + length.to_bytes(2, "big") + value


def build_cdp_payload(device_id: str, port_id: str = "FastEthernet0/1") -> bytes:
    """
    Construye el payload CDP completo con los TLVs necesarios.
    El switch almacenara device_id como un vecino unico.
    """
    tlvs = b""

    # TLV: Device ID (identificador unico del "vecino")
    tlvs += build_cdp_tlv(CDP_TLV_DEVICE_ID, device_id.encode())

    # TLV: Capabilities (Router + Switch)
    tlvs += build_cdp_tlv(CDP_TLV_CAPS, b"\x00\x00\x00\x29")

    # TLV: Software Version
    version = b"Cisco IOS Software, Version 15.2(7)E, RELEASE SOFTWARE"
    tlvs += build_cdp_tlv(CDP_TLV_VERSION, version)

    # TLV: Platform
    platform = b"cisco WS-C2960-24TC-L"
    tlvs += build_cdp_tlv(CDP_TLV_PLATFORM, platform)

    # TLV: Port ID
    tlvs += build_cdp_tlv(CDP_TLV_PORT_ID, port_id.encode())

    # CDP Header: Version(1) + TTL(180s) + Checksum(0 - scapy calcula)
    cdp_header = b"\x02\xb4\x00\x00"

    return cdp_header + tlvs


def build_cdp_packet(src_mac: str, device_id: str) -> bytes:
    """
    Construye el paquete Ethernet completo con CDP encapsulado en LLC/SNAP.
    Estructura: Ethernet 802.3 -> LLC (DSAP/SSAP=0xAA) -> SNAP -> CDP payload
    """
    cdp_payload = build_cdp_payload(device_id)

    # Encapsulacion LLC + SNAP
    llc_snap = (
        b"\xaa\xaa\x03"          # LLC: DSAP=0xAA, SSAP=0xAA, Control=0x03
        + CDP_SNAP_OUI            # SNAP OUI Cisco
        + CDP_SNAP_PID            # SNAP PID = CDP
        + cdp_payload
    )

    # Frame Ethernet 802.3 (con campo longitud, no tipo)
    src_bytes  = bytes(int(x, 16) for x in src_mac.split(":"))
    dst_bytes  = bytes(int(x, 16) for x in CDP_MULTICAST_MAC.split(":"))
    length     = len(llc_snap).to_bytes(2, "big")
    frame      = dst_bytes + src_bytes + length + llc_snap

    # Padding hasta 60 bytes minimo Ethernet
    if len(frame) < 60:
        frame += b"\x00" * (60 - len(frame))

    return frame


